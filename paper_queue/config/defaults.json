{
  "agent": {
    "backend": "claude-glm",
    "command": "CLAUDE_CONFIG_DIR=/home/agent-user/.claude-glm claude --dangerously-skip-permissions",
    "model": "glm-5.1",
    "timeout_seconds": 1800
  },
  "skill": {
    "name": "notebooklm-paper-reader",
    "source_dir": "/workspace/paper_reading/notebooklm-paper-reader"
  },
  "storage": {
    "subdir": "paper"
  },
  "evaluation": {
    "assets_dir": "benchmarks/assets",
    "paragraph_batch_size": 12,
    "self_review_rounds": 3,
    "max_paragraph_chars": 1800,
    "agent_timeout_seconds": 45,
    "swiftscholar_pdf_dir": "/workspace/paper_reading/benchmarks/swiftscholar_pdfs"
  },
  "prompts": {
    "metadata": "metadata_v1.txt",
    "metadata_agent": "metadata_agent_v1.txt",
    "notes_preflight": "notes_preflight_v1.txt",
    "figure_placement": "figure_placement_v1.txt",
    "notes": "notes_v1.txt",
    "structure_analysis": "structure_analysis_v1.txt",
    "readability_review": "readability_review_v1.txt",
    "benchmark_paragraph_points": "benchmark_paragraph_points_v1.txt",
    "benchmark_coverage_review": "benchmark_coverage_review_v1.txt",
    "benchmark_placement_review": "benchmark_placement_review_v1.txt",
    "benchmark_length_review": "benchmark_length_review_v1.txt",
    "routing": "routing_v1.txt"
  }
}
